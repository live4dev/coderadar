DATABASE_URL=sqlite:///./coderadar.db
REPOS_CACHE_DIR=./repos_cache
LOG_LEVEL=INFO

# Bitbucket credentials (optional, per-repo override possible)
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=

# GitLab credentials (optional, per-repo override possible)
GITLAB_TOKEN=
GITLAB_BASE_URL=https://gitlab.com

# Git history: max commits to scan per repo (0 = unlimited)
GIT_HISTORY_SCAN_LIMIT=0
